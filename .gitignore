.history
.svn/
.swiftpm/
migrate_working_dir/

# macOS
.DS_Store

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter / Dart
.flutter-plugins
.flutter-plugins-dependencies
.flutter-plugins-dependencies*
.packages
.pub/
.pub-cache/
.dart_tool/
**/doc/api/
/build/
/coverage/

# Duplicate / misnamed Flutter tool outputs (spaces in filename)
flutter_export_environment*.sh
Generated*.xcconfig

# Android build
android/.gradle/
/android/app/debug
/android/app/profile
/android/app/release

# iOS (Flutter generated) — also see ios/.gitignore
**/ios/Flutter/.last_build_id
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Flutter.podspec

# Xcode / CocoaPods (workspace metadata is tracked; xcuserdata in ios/.gitignore)
ios/Pods/
DerivedData/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json
